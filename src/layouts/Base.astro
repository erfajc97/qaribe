---
import "../styles/global.css";
import { SITE, EVENT } from "../lib/event";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = `${EVENT.brand} ${EVENT.brandSuffix} ${EVENT.year} | El encuentro privado de líderes digitales en Four Seasons Cartagena`,
  description = "Encuentro ejecutivo privado en Cartagena sobre inteligencia artificial, Insurtech e innovación tecnológica. Four Seasons · 24–26 de septiembre de 2026. Por invitación.",
  canonical = "/",
} = Astro.props;

const canonicalUrl = `${SITE.url}${canonical}`;
const ogImage = `${SITE.url}${SITE.ogImage}`;

const eventLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: SITE.name,
  description,
  startDate: EVENT.startDate,
  endDate: EVENT.endDate,
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  eventStatus: "https://schema.org/EventScheduled",
  location: {
    "@type": "Place",
    name: "Four Seasons Hotel Cartagena",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Cartagena",
      addressRegion: "Bolívar",
      addressCountry: "CO",
    },
  },
  image: [ogImage],
  organizer: [
    { "@type": "Organization", name: "Shepwashi", url: "https://shepwashi.com" },
    { "@type": "Organization", name: "Luntriqa",  url: "https://luntriqa.com" },
  ],
  inLanguage: ["es"],
};
---
<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#050e1a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="Qarybe Summit" />
    <meta name="geo.region" content="CO-BOL" />
    <meta name="geo.placename" content="Cartagena de Indias" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Qarybe Summit" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CO" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/images/logo.png" type="image/png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cormorant+SC:wght@300;400&family=Montserrat:wght@200;300;400;500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cormorant+SC:wght@300;400&family=Montserrat:wght@200;300;400;500&display=swap" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(eventLd)} />
  </head>

  <body>
    <div id="cursor-spotlight" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    <div class="cursor-dot"  aria-hidden="true"></div>

    <slot />

    <script is:inline>
      // Always start at top on (re)load
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      window.addEventListener("beforeunload", () => window.scrollTo(0, 0));
      window.addEventListener("load", () => {
        if (!location.hash) window.scrollTo(0, 0);
      });

      // Fade-up: re-animate both entering AND leaving viewport
      (function () {
        const els = document.querySelectorAll(".fade-up");
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              e.target.classList.toggle("visible", e.isIntersecting);
            });
          },
          { threshold: 0.10, rootMargin: "0px 0px -5% 0px" }
        );
        els.forEach((el) => io.observe(el));
      })();

      // Cursor spotlight + custom cursor — fine-pointer only
      (function () {
        const spot = document.getElementById("cursor-spotlight");
        const ring = document.querySelector(".cursor-ring");
        const dot  = document.querySelector(".cursor-dot");
        if (!spot || !ring || !dot) return;
        if (window.matchMedia("(hover: none), (pointer: coarse)").matches) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        let raf = 0;
        let mx = window.innerWidth / 2, my = window.innerHeight / 3;
        let rx = mx, ry = my;
        let sx = mx, sy = my;

        function tick() {
          // ring: smoother trailing
          rx += (mx - rx) * 0.22;
          ry += (my - ry) * 0.22;
          ring.style.transform =
            "translate3d(" + rx + "px, " + ry + "px, 0) translate(-50%, -50%)";

          // dot: tighter
          dot.style.transform =
            "translate3d(" + mx + "px, " + my + "px, 0) translate(-50%, -50%)";

          // spotlight: slowest
          sx += (mx - sx) * 0.18;
          sy += (my - sy) * 0.18;
          spot.style.setProperty("--mx", sx + "px");
          spot.style.setProperty("--my", sy + "px");

          raf = requestAnimationFrame(tick);
        }

        document.addEventListener("pointermove", (e) => {
          mx = e.clientX; my = e.clientY;
          if (!spot.classList.contains("on")) {
            spot.classList.add("on");
            ring.classList.add("on");
            dot.classList.add("on");
          }
        }, { passive: true });

        document.addEventListener("pointerleave", () => {
          spot.classList.remove("on");
          ring.classList.remove("on");
          dot.classList.remove("on");
        });

        // hover state on interactive targets
        const HOVER_SEL = 'a, button, [role="button"], input, select, textarea, label, .card, .venue-item, .dia, .perfil-row';
        document.addEventListener("pointerover", (e) => {
          if (e.target.closest && e.target.closest(HOVER_SEL)) {
            ring.classList.add("hover");
          }
        });
        document.addEventListener("pointerout", (e) => {
          if (e.target.closest && e.target.closest(HOVER_SEL)) {
            ring.classList.remove("hover");
          }
        });

        tick();
      })();
    </script>
  </body>
</html>
