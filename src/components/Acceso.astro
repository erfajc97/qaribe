---
import { FOCUS_AREAS, FORM_ENDPOINT } from "../lib/event";
---
<section
  id="acceso"
  class="section-pad relative"
  style="background: var(--navy3);"
>
  <div class="max-w-3xl mx-auto text-center flex flex-col items-center">
    <p
      class="h-italic-gold fade-up"
      style="font-size: clamp(20px, 2.5vw, 28px); margin-bottom: 36px; max-width: 620px;"
    >
      Lo que viene, se verá aquí primero.<br />
      La pregunta es si vas a estar.
    </p>

    <p class="eyebrow fade-up" data-d="1" style="margin-bottom: 18px;">Acceso</p>

    <h2 class="fade-up" data-d="1" style="font-family: var(--font-display); font-weight: 300; font-size: clamp(36px, 4.5vw, 60px); line-height: 1.1; color: var(--white); letter-spacing: -1px; max-width: 540px;">
      Solicitar acceso
    </h2>

    <p class="body-copy fade-up" data-d="2" style="max-width: 520px; margin-top: 22px; margin-bottom: 36px;">
      Qarybe es una lista cerrada. Deja tus datos; el equipo revisa cada perfil.
      Si encajas, te buscamos.
    </p>

    <form
      class="form-wrap fade-up w-full"
      data-d="3"
      id="qarybe-form"
      action={FORM_ENDPOINT || "#"}
      method="POST"
    >
      <input type="text" name="nombre" placeholder="Nombre" required autocomplete="name" />
      <input type="text" name="empresa_cargo" placeholder="Empresa y cargo" required />
      <input type="email" name="email" placeholder="Email" required autocomplete="email" />
      <select name="area" required>
        <option value="" disabled selected>Área de enfoque</option>
        {FOCUS_AREAS.map((f) => <option value={f}>{f}</option>)}
      </select>
      <button type="submit" class="form-submit" id="qarybe-submit">
        Solicitar acceso
      </button>
    </form>

    <p class="form-feedback microcopy" id="qarybe-feedback" role="status" aria-live="polite"></p>

    <p class="microcopy fade-up" data-d="4" style="margin-top: 16px; max-width: 460px;">
      La solicitud no garantiza el acceso.<br />
      Cada perfil será revisado por el equipo organizador.
    </p>
  </div>
</section>

<style>
  .form-feedback {
    margin-top: 18px;
    min-height: 14px;
    transition: color 0.3s ease;
  }
  .form-feedback.ok    { color: var(--gold2); }
  .form-feedback.error { color: #e08a6a; }
</style>

<script is:inline define:vars={{ FORM_ENDPOINT }}>
  (function () {
    const form = document.getElementById("qarybe-form");
    const btn  = document.getElementById("qarybe-submit");
    const fb   = document.getElementById("qarybe-feedback");
    if (!form || !btn) return;

    function setFeedback(msg, type) {
      if (!fb) return;
      fb.textContent = msg;
      fb.classList.remove("ok", "error");
      if (type) fb.classList.add(type);
    }

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      if (btn.disabled) return;

      // Demo mode — no endpoint configured yet
      if (!FORM_ENDPOINT) {
        btn.textContent = "Solicitud enviada ✓";
        btn.disabled = true;
        btn.style.opacity = "0.6";
        btn.style.cursor = "default";
        setFeedback("Modo demo — configura FORM_ENDPOINT para envíos reales.", "ok");
        return;
      }

      // Live mode — submit to Formspree / API
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = "Enviando...";
      setFeedback("", null);

      fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      })
        .then(function (res) {
          if (res.ok) {
            btn.textContent = "Solicitud enviada ✓";
            btn.style.opacity = "0.6";
            btn.style.cursor = "default";
            form.reset();
            setFeedback("Recibimos tu solicitud. El equipo revisará tu perfil.", "ok");
          } else {
            throw new Error("bad response");
          }
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = original;
          setFeedback("No se pudo enviar. Intenta de nuevo o escríbenos directamente.", "error");
        });
    });
  })();
</script>
