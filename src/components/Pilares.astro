---
import { PILARES } from "../lib/event";
---
<section
  id="pilares"
  class="section-pad relative"
  style="background: var(--navy);"
>
  <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-start max-w-7xl mx-auto">
    <div class="fade-up lg:pr-8 lg:border-r lg:border-[color:var(--border)]">
      <p class="eyebrow" style="margin-bottom: 28px;">Cuatro Pilares</p>
      <h2 class="h-section" style="max-width: 480px;">
        Donde la tecnología deja de ser teoría.
      </h2>
      <p class="body-copy" style="max-width: 380px; margin-top: 32px;">
        Construcción a medida e IA de automatización, Insurtech y el futuro
        regional. Las cuatro áreas donde se está tomando — ahora — la decisión
        de la próxima década.
      </p>

      <div class="mt-12 inline-flex items-center gap-4">
        <span class="block w-12 h-px bg-[color:var(--gold)]"></span>
        <span class="microcopy" style="color: var(--gold); letter-spacing: 4px;">Shepwashi · Luntriqa</span>
      </div>
    </div>

    <div class="cards-grid">
      {PILARES.map((p, i) => (
        <article class="card group fade-up" data-d={String(Math.min(4, i + 1))}>
          <div class="flex items-baseline justify-between mb-2">
            <span class="deco-num">{p.n}</span>
          </div>
          <div class="card-accent"></div>
          <h3 class="card-title" style="margin-bottom: 12px;">{p.title}</h3>
          <p class="card-body">{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
