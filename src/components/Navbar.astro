---
import { NAV_LINKS } from "../lib/event";
---
<nav class="nav-root" id="qarybe-nav" aria-label="Navegación principal">
  <a href="#top" class="nav-brand">QARYBE <span class="gold">SUMMIT</span></a>

  <div class="nav-desktop flex items-center gap-12">
    {NAV_LINKS.map((l) => (
      <a href={l.href} class="nav-link">{l.label}</a>
    ))}
  </div>

  <a href="#acceso" class="nav-cta nav-desktop">Solicitar Introducción</a>

  <button
    type="button"
    class="nav-burger items-center justify-center w-10 h-10"
    aria-label="Abrir menú"
    aria-expanded="false"
    id="nav-burger"
  >
    <span class="block w-5 h-px bg-[var(--gold)] relative">
      <span class="absolute -top-1.5 left-0 w-5 h-px bg-[var(--gold)]"></span>
      <span class="absolute  top-1.5 left-0 w-5 h-px bg-[var(--gold)]"></span>
    </span>
  </button>
</nav>

<div class="mobile-panel" id="mobile-panel" aria-hidden="true">
  <button
    type="button"
    class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center text-[var(--gold)]"
    id="mobile-close"
    aria-label="Cerrar menú"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
  </button>

  <div class="text-center mb-4">
    <div class="nav-brand">QARYBE <span class="gold">SUMMIT</span></div>
  </div>

  <ul class="flex flex-col items-center gap-8 list-none p-0 m-0">
    {NAV_LINKS.map((l) => (
      <li><a href={l.href} class="nav-link" data-mobile-link style="font-size: 14px; letter-spacing: 5px;">{l.label}</a></li>
    ))}
  </ul>

  <a href="#acceso" class="nav-cta" data-mobile-link style="margin-top: 8px;">Solicitar Introducción</a>
</div>

<script is:inline>
  (function () {
    const nav = document.getElementById("qarybe-nav");
    const burger = document.getElementById("nav-burger");
    const panel = document.getElementById("mobile-panel");
    const close = document.getElementById("mobile-close");

    function onScroll() {
      if (!nav) return;
      nav.classList.toggle("scrolled", window.scrollY > 60);
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    function openPanel() {
      panel?.classList.add("open");
      panel?.setAttribute("aria-hidden", "false");
      burger?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }
    function closePanel() {
      panel?.classList.remove("open");
      panel?.setAttribute("aria-hidden", "true");
      burger?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    burger?.addEventListener("click", openPanel);
    close?.addEventListener("click", closePanel);
    panel?.querySelectorAll("[data-mobile-link]").forEach((a) => {
      a.addEventListener("click", closePanel);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closePanel();
    });
  })();
</script>
