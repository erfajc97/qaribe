---
interface Props {
  size?: number;
  class?: string;
  rays?: boolean;
}
const { size = 140, class: className = "", rays = true } = Astro.props;
const w = size;
const h = Math.round(size * 118 / 140);
const id = `faro-${Math.random().toString(36).slice(2, 8)}`;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={w}
  height={h}
  viewBox="0 0 140 118"
  class={className}
  role="img"
  aria-label="Faro Qarybe"
>
  <defs>
    <radialGradient id={`glow-${id}`} cx="50%" cy="22%" r="48%">
      <stop offset="0%"   stop-color="#e2c47a" stop-opacity="0.85"/>
      <stop offset="60%"  stop-color="#c9a84c" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#c9a84c" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id={`bar-${id}`} x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#6a5020"/>
      <stop offset="40%"  stop-color="#e2c47a"/>
      <stop offset="60%"  stop-color="#e2c47a"/>
      <stop offset="100%" stop-color="#6a5020"/>
    </linearGradient>
  </defs>

  {rays && (
    <>
      <circle cx="70" cy="34" r="44" fill={`url(#glow-${id})`} opacity="0.55"/>
      <line x1="70" y1="34" x2="6"   y2="34" stroke="#c9a84c" stroke-width="0.5" opacity="0.35"/>
      <line x1="70" y1="34" x2="134" y2="34" stroke="#c9a84c" stroke-width="0.5" opacity="0.35"/>
    </>
  )}

  <rect x="62" y="20" width="16" height="5" rx="1" fill={`url(#bar-${id})`}/>

  <circle cx="70" cy="34" r="9" fill="#e2c47a" opacity="0.30"/>
  <circle cx="70" cy="34" r="5" fill="#fff8e0" opacity="0.95"/>

  <rect x="54" y="42"  width="32" height="6" rx="1" fill={`url(#bar-${id})`}/>
  <rect x="51" y="52"  width="38" height="6" rx="1" fill={`url(#bar-${id})`}/>
  <rect x="47" y="62"  width="46" height="6" rx="1" fill={`url(#bar-${id})`}/>
  <rect x="43" y="72"  width="54" height="6" rx="1" fill={`url(#bar-${id})`}/>
  <rect x="39" y="82"  width="62" height="6" rx="1" fill={`url(#bar-${id})`}/>
  <rect x="35" y="92"  width="70" height="6" rx="1" fill={`url(#bar-${id})`}/>
  <rect x="31" y="102" width="78" height="6" rx="1" fill={`url(#bar-${id})`}/>
</svg>
