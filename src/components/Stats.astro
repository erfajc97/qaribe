---
import { MOMENTO } from "../lib/event";
---
<section
  id="momento"
  class="section-pad relative"
  style="background: var(--navy3);"
>
  <div class="max-w-3xl mx-auto text-center flex flex-col items-center">
    <p class="eyebrow fade-up" style="margin-bottom: 22px;">{MOMENTO.eyebrow}</p>

    <h2 class="h-section fade-up" data-d="1" style="max-width: 720px;">
      {MOMENTO.title}
    </h2>

    {MOMENTO.body.map((p, i) => (
      <p class="body-copy fade-up" data-d={String(Math.min(3, i + 2))} style="max-width: 620px; margin-top: 24px;">
        {p}
      </p>
    ))}
  </div>
</section>
