---
import FaroSvg from "./FaroSvg.astro";
import { EVENT } from "../lib/event";
---
<section
  id="top"
  class="relative overflow-hidden"
  style="background: var(--navy); min-height: 100vh; padding-top: 130px; padding-bottom: 80px;"
>
  <!-- Layer 1: Cartagena bg image, atmospheric, heavily darkened + blurred -->
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <img
      src="/images/hero-bg.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover hero-img-anim"
      style="filter: brightness(0.38) saturate(0.45) contrast(1.05) blur(6px); transform: scale(1.08);"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(5,14,26,0.88) 0%, rgba(5,14,26,0.82) 35%, rgba(7,17,31,0.92) 70%, rgba(5,14,26,1) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 30%, rgba(201,168,76,0.14), transparent 55%), radial-gradient(ellipse at 50% 110%, rgba(5,14,26,0.7), transparent 60%);"></div>
  </div>

  <!-- Layer 2: particles canvas -->
  <canvas id="particles-canvas" aria-hidden="true"></canvas>

  <!-- Layer 3: content -->
  <div class="relative z-10 flex flex-col items-center text-center px-6">
    <p class="eyebrow fade-up" style="margin-bottom: 36px;">
      Por Invitación · {EVENT.year}
    </p>

    <div class="fade-up faro-wrap" data-d="1" style="margin-bottom: 8px;">
      <FaroSvg size={120} rays={true} />
    </div>

    <h1 class="h-display fade-up" data-d="2" style="margin-top: -6px;">{EVENT.brand}</h1>

    <p
      class="fade-up"
      data-d="3"
      style="font-family: var(--font-sc); font-weight: 300; font-size: clamp(14px, 1.8vw, 22px); letter-spacing: 10px; color: var(--gold); margin-top: 14px;"
    >
      {EVENT.brandSuffix} {EVENT.year}
    </p>

    <p
      class="fade-up body-copy"
      data-d="4"
      style="max-width: 520px; margin-top: 36px; font-size: 14px; line-height: 1.9; color: rgba(245, 240, 232, 0.82);"
    >
      El encuentro privado que está definiendo<br class="hidden sm:inline" />
      el futuro digital de América Latina y el Caribe.
    </p>

    <p
      class="fade-up body-copy"
      data-d="5"
      style="max-width: 500px; margin-top: 18px; font-size: 12.5px; line-height: 1.9;"
    >
      Qarybe Summit 2026 no es una conferencia. Es la sala donde los líderes
      que están construyendo el futuro digital de la región se reúnen por
      primera vez. Por invitación. Four Seasons Cartagena. 24–26 de septiembre de 2026.
    </p>

    <div class="fade-up flex flex-wrap items-center justify-center gap-4" data-d="5" style="margin-top: 40px;">
      <a href="#acceso" class="btn-primary">Quiero mi lugar</a>
      <a href="#experiencia" class="btn-ghost">Ver la experiencia</a>
    </div>

    <p class="fade-up microcopy" data-d="5" style="margin-top: 22px; max-width: 460px; color: rgba(245, 240, 232, 0.50);">
      Acceso por invitación. Cupos limitados y sujetos a validación del perfil ejecutivo.
    </p>
  </div>

</section>

<style>
  .faro-wrap {
    filter: drop-shadow(0 0 32px rgba(226, 196, 122, 0.25));
    animation: faro-pulse 4.5s ease-in-out infinite;
  }
  @keyframes faro-pulse {
    0%, 100% { filter: drop-shadow(0 0 28px rgba(226, 196, 122, 0.22)); }
    50%      { filter: drop-shadow(0 0 44px rgba(226, 196, 122, 0.42)); }
  }

  .hero-img-anim {
    animation: hero-drift 26s ease-in-out infinite alternate;
  }
  @keyframes hero-drift {
    from { transform: scale(1.08) translate3d(0, 0, 0); }
    to   { transform: scale(1.14) translate3d(-1.5%, -1%, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .faro-wrap, .hero-img-anim { animation: none !important; }
  }
</style>

<script is:inline>
  (function () {
    const canvas = document.getElementById("particles-canvas");
    if (!canvas) return;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let W = 0, H = 0, pts = [], dpr = Math.min(window.devicePixelRatio || 1, 2);
    let raf = 0;

    function init() {
      const rect = canvas.parentElement.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + "px";
      canvas.style.height = H + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const count = Math.min(90, Math.floor((W * H) / 16000));
      pts = [];
      for (let i = 0; i < count; i++) {
        pts.push({
          x: Math.random() * W,
          y: Math.random() * H,
          r: Math.random() * 1.2 + 0.25,
          o: Math.random() * 0.35 + 0.07,
          speed: Math.random() * 0.12 + 0.035,
          dir: Math.random() > 0.5 ? 1 : -1,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (const p of pts) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(226, 196, 122, " + p.o.toFixed(3) + ")";
        ctx.fill();
        p.y -= p.speed;
        p.o += 0.0018 * p.dir;
        if (p.o > 0.45 || p.o < 0.05) p.dir *= -1;
        if (p.y < -4) {
          p.y = H + 4;
          p.x = Math.random() * W;
        }
      }
      raf = requestAnimationFrame(draw);
    }

    function start() {
      init();
      cancelAnimationFrame(raf);
      draw();
    }

    start();
    let to;
    window.addEventListener("resize", () => {
      clearTimeout(to);
      to = setTimeout(start, 150);
    });

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else draw();
    });
  })();
</script>
